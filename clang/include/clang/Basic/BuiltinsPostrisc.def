///////////////////////////////////////////////////////////////////////////////////////
// vector common
///////////////////////////////////////////////////////////////////////////////////////
#define BUILTIN_TYPE_FH  "x" // support _Float16 (x), not __fp16 (h)
#define BUILTIN_TYPE_FS  "f"
#define BUILTIN_TYPE_FD  "d"
#define BUILTIN_TYPE_FQ  "Ld"
#define BUILTIN_TYPE_VFH "V8" BUILTIN_TYPE_FH
#define BUILTIN_TYPE_VFS "V4" BUILTIN_TYPE_FS
#define BUILTIN_TYPE_VFD "V2" BUILTIN_TYPE_FD
#define BUILTIN_TYPE_VIB "V16c"
#define BUILTIN_TYPE_VIH "V8s"
#define BUILTIN_TYPE_VIW "V4i"
#define BUILTIN_TYPE_VID "V2Oi"

#define BUILTIN_TYPE_VUB "V16Uc"
#define BUILTIN_TYPE_VUH "V8Us"
#define BUILTIN_TYPE_VUW "V4Ui"
#define BUILTIN_TYPE_VUD "V2UOi"

#define BUILTIN_POSTRISC_R2(NAME, TA, TB)                                        \
  TARGET_BUILTIN(__builtin_postrisc_##NAME,                                      \
      BUILTIN_TYPE_##TA BUILTIN_TYPE_##TB                                        \
      , "ncV:128:", "vector")

#define BUILTIN_POSTRISC_R3(NAME, TA, TB, TC)                                    \
  TARGET_BUILTIN(__builtin_postrisc_##NAME,                                      \
      BUILTIN_TYPE_##TA BUILTIN_TYPE_##TB BUILTIN_TYPE_##TC                      \
      , "ncV:128:", "vector")

#define BUILTIN_POSTRISC_R4(NAME, TA, TB, TC, TD)                                \
  TARGET_BUILTIN(__builtin_postrisc_##NAME,                                      \
      BUILTIN_TYPE_##TA BUILTIN_TYPE_##TB BUILTIN_TYPE_##TC BUILTIN_TYPE_##TD    \
      , "ncV:128:", "vector")

BUILTIN_POSTRISC_R3(clmulll, VID, VID, VID)
BUILTIN_POSTRISC_R3(clmulhl, VID, VID, VID)
BUILTIN_POSTRISC_R3(clmulhh, VID, VID, VID)

